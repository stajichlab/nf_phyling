nextflow.enable.dsl = 2
process.cache = 'lenient'
params {
    // ── Required ───────────────────────────────────────────────────
    seq_type   = 'protein'                          // 'cds' or 'protein'
    input      = null                               // path to cds/ or pep/ directory
    prefix     = null                               // project base name, e.g. mucor_jena_v8
    markerset  = 'fungi_odb12'   		    // comma-separated list

    // ── Output ────────────────────────────────────────────────────
    outdir       = 'results'
    publish_mode = 'copy'   // 'copy', 'link', or 'symlink'

    // ── PHYLING marker DB cache ───────────────────────────────────
    // Where `phyling download` stores markersets (exported as $PHYLING_DB).
    // null => <workDir>/phyling, a run-local cache under the work folder.
    // Point this at a shared persistent path to reuse across runs, e.g.
    //   --phyling_db /bigdata/stajichlab/shared/phyling_db
    phyling_db = null

    // ── phyling filter ────────────────────────────────────────────
    top_n_to_keep = 80      // TOP_N_TOVERR: number of top markers to retain (phyling filter -n)

    // ── IQ-TREE ───────────────────────────────────────────────────
    rcluster    = 10        // -rcluster: reduce partition space (%)
    bs_count    = 1000      // -B: ultrafast bootstrap replicates
    alrt_count  = 1000      // --alrt: SH-aLRT replicates
    iqtree_max_cpus = 16    // IQ-TREE cpu request; -T AUTO scales down within it (saturates earlier than RAxML)

    // ── FastTreeMP ────────────────────────────────────────────────
    // Third (fast, approximate-ML) tree builder on the concatenated alignment.
    // FastTree applies a single model (no partitions), so it cannot consume the
    // ModelTest-NG scheme; pick the model directly here.
    // Runs twice per markerset: a -nosupport tree and a -boot support tree
    // (SH-like local supports — not full nonparametric bootstraps).
    fasttree_max_cpus = 8       // OMP threads (FastTree parallelism saturates early)
    fasttree_model_prot = '-lg' // protein model: -lg, -wag, or '' for the JTT default
    fasttree_model_dna  = '-gtr' // DNA model: -gtr, or '' for the Jukes-Cantor default
    fasttree_boot       = 1000  // -boot resamples for the SH-like local support tree

    // ── RAxML-NG ──────────────────────────────────────────────────
    pars_trees    = 10      // number of parsimony starting trees
    bs_trees_cds  = 500     // bootstrap replicates for CDS seq_type
    bs_trees_pep  = 100     // bootstrap replicates for PEP seq_type
    raxml_min_cpus = 2      // floor for dynamic RAXMLNG_ALL cpu request
    raxml_max_cpus = 32     // cap for dynamic RAXMLNG_ALL cpu request

    // ── Resource ceilings for the `vm` profile ────────────────────
    // Used only with -profile vm to clamp every process's requested
    // cpus/memory/time down to a small machine's capacity. Override on
    // the command line, e.g. --max_cpus 8 --max_memory 30.GB
    max_cpus   = 4
    max_memory = 14.GB
    max_time   = 72.h
}

// ── Include resource labels ────────────────────────────────────────
includeConfig 'conf/base.config'

profiles {
    // ── SLURM executor ────────────────────────────────────────────
    // Executor only — software provisioning comes from a separate profile
    // (singularity / pixi / modules) and queue names from a site profile:
    //   -profile singularity_slurm,ucr_hpcc   (primary, portable)
    //   -profile slurm,modules,ucr_hpcc       (UCR environment modules)
    //   -profile slurm -c my_site.config       (any cluster)
    slurm {
        process.executor = 'slurm'
    }

    // ── UCR HPCC site (highmem / epyc queues) ────────────────────
    // Combine with slurm or pixi_slurm: -profile slurm,ucr_hpcc
    ucr_hpcc {
        includeConfig 'conf/ucr_hpcc.config'
    }

    // ── Singularity / Apptainer containers (local executor) ────────
    // Software comes from BioContainers images; see conf/singularity.config.
    singularity {
        includeConfig 'conf/singularity.config'
    }

    // ── Singularity + SLURM ───────────────────────────────────────
    // Queue names still needed — combine with a site profile:
    //   -profile singularity_slurm,ucr_hpcc
    singularity_slurm {
        process.executor = 'slurm'
        includeConfig 'conf/singularity.config'
    }

    // ── Pixi-managed environment (local executor) ──────────────────
    pixi {
        process.beforeScript = """
            eval "\$(pixi shell-hook --manifest-path ${projectDir}/pixi.toml 2>/dev/null)" || true
        """.stripIndent().trim()
    }

    // ── Pixi + SLURM ──────────────────────────────────────────────
    // Queue names still needed — combine with a site profile:
    //   -profile pixi_slurm,ucr_hpcc
    pixi_slurm {
        process.executor = 'slurm'
        process.beforeScript = """
            eval "\$(pixi shell-hook --manifest-path ${projectDir}/pixi.toml 2>/dev/null)" || true
        """.stripIndent().trim()
    }

    // ── Environment modules (site-specific software) ──────────────
    // ALTERNATIVE to singularity/pixi for clusters that expose tools as
    // environment modules. Module names are UCR HPCC-specific; see
    // conf/modules.config. Combine with an executor + site profile:
    //   -profile slurm,modules,ucr_hpcc
    modules {
        includeConfig 'conf/modules.config'
    }

    // ── Environment modules + SLURM ───────────────────────────────
    // Queue names still needed — combine with a site profile:
    //   -profile modules_slurm,ucr_hpcc
    modules_slurm {
        process.executor = 'slurm'
        includeConfig 'conf/modules.config'
    }

    // ── Local execution (testing) ──────────────────────────────────
    local {
        process.executor = 'local'
    }

    // ── Small VM / laptop (cap resources to the machine) ──────────
    // Clamps every process's requested cpus/memory/time down to the
    // params.max_* ceilings so labels like process_high_memory (cpus=24)
    // fit a small host. Combine with a software profile, e.g.
    //   -profile singularity,vm                 (defaults: 4 cpus / 14 GB)
    //   -profile singularity,vm --max_cpus 8 --max_memory 30.GB
    vm {
        process.executor = 'local'
        process.resourceLimits = [
            cpus  : params.max_cpus,
            memory: params.max_memory,
            time  : params.max_time
        ]
    }
}

// ── Reporting ─────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/${params.prefix}.${params.seq_type}.${params.markerset}.timeline.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/${params.prefix}.${params.seq_type}.${params.markerset}_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/${params.prefix}.${params.seq_type}.${params.markerset}.report.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/${params.prefix}.${params.seq_type}.${params.markerset}.dag.svg"
    overwrite = true
}
