// Singularity / Apptainer software provisioning.
//
// Enabled via the `singularity` (local executor) or `singularity_slurm`
// (SLURM executor) profiles in nextflow.config. Combine with a site profile
// for queue names, e.g.:
//   -profile singularity_slurm,ucr_hpcc
//
// Images are pulled from the Bioconda/BioContainers registry on quay.io and
// cached in the directory given by the NXF_SINGULARITY_CACHEDIR environment
// variable (set it in your shell profile or sbatch script, e.g. a shared lab
// path so images aren't re-pulled per user):
//   export NXF_SINGULARITY_CACHEDIR=/bigdata/stajichlab/shared/singularity_cache
// On clusters whose compute nodes lack outbound network, pre-pull on a login
// node, e.g.:
//   singularity pull docker://quay.io/biocontainers/phyling:2.3.1--pyhdfd78af_0
// or run the pipeline once on a networked node so Nextflow populates the cache.

singularity {
    enabled    = true
    autoMounts = true                       // auto-bind $HOME, $PWD, etc.
}

// Per-process container assignments. Kept here (rather than in each module's
// main.nf) so the entire container layer lives in one file and the modules
// stay provisioning-agnostic.
process {
    withName: 'PHYLING_DOWNLOAD|PHYLING_ALIGN|PHYLING_FILTER|PHYLING_TREE' {
        container = 'quay.io/biocontainers/phyling:2.3.1--pyhdfd78af_0'
    }
    withName: 'PHYKIT_CONCAT' {
        container = 'quay.io/biocontainers/phykit:2.1.93--pyhdfd78af_0'
    }
    withName: 'MODELTEST_NG' {
        container = 'quay.io/biocontainers/modeltest-ng:0.1.7--hf316886_3'
    }
    // v3 image — the IQ-TREE modules invoke the `iqtree3` binary, which only
    // exists in the 3.x line (not the iqtree2 images).
    withName: 'IQTREE_MF|IQTREE_BOOTSTRAP' {
        container = 'quay.io/biocontainers/iqtree:3.1.2--h8471819_0'
    }
    withName: 'RAXMLNG_PARSE|RAXMLNG_ALL' {
        container = 'quay.io/biocontainers/raxml-ng:2.0.2--h870a6a7_0'
    }
}
