// UCR HPCC (hpcc.ucr.edu) site configuration.
// Combine with slurm or pixi_slurm profile:
//   -profile slurm,ucr_hpcc
//   -profile pixi_slurm,ucr_hpcc

process {
    withLabel: process_high_memory {
        queue = 'highmem'
    }
    withLabel: process_high {
    }
    withLabel: process_medium {
    }
    withLabel: process_low {
    }
    withLabel: process_short {
        queue = 'short'
    }
    withLabel: process_tree {
    }

    // Fine-grained overrides for processes that sit across label boundaries
    withName: 'PHYLING_ALIGN'    {
        // First attempt on epyc; on retry move to highmem and grab its large RAM.
        queue  = { task.attempt > 1 ? 'highmem' : '' }
        memory = { task.attempt == 1 ? 96.GB : ( task.attempt == 2 ? 200.GB : 750.GB ) }
        cpus   = { task.attempt > 1 ? 32 : 24 }
    }
    withName: 'PHYLING_FILTER'   { cpus = 24 }
    withName: 'PHYLING_TREE'     { cpus = 24 }
    withName: 'PHYKIT_CONCAT'    { queue = 'short'  }
    withName: 'MODELTEST_NG'     { cpus = 32 }
    // IQTREE cpus are set dynamically from RAxML-NG's recommended thread count
    // (carried via rec_threads) in modules/local/iqtree/*/main.nf — do not pin here.
    withName: 'RAXMLNG_PARSE'    { cpus = 1 }
    // RAXMLNG_ALL cpus are set dynamically from RAxML-NG's recommended thread count
    // in modules/local/raxmlng/all/main.nf — do not pin here (a withName override would win).
}
