// Environment-modules software provisioning.
//
// This is an ALTERNATIVE to the singularity / pixi software profiles, for
// sites that provide the tools as environment modules rather than containers.
// Singularity and pixi are the primary (portable) ways to run this pipeline;
// use this only on a cluster whose module names match those below.
//
// NOTE: the module names here are UCR HPCC modules and are site-specific.
// On another cluster, override them with your own `-c my_modules.config`.
//
// Combine with an executor/site profile, e.g.:
//   -profile slurm,modules,ucr_hpcc
//   -profile modules_slurm,ucr_hpcc

process {
    withName: 'PHYLING_DOWNLOAD|PHYLING_ALIGN|PHYLING_FILTER|PHYLING_TREE' {
        beforeScript = '''
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "$(conda shell.bash hook)"
            module load phyling/2.3.1
        '''
    }
    withName: 'PHYKIT_CONCAT' {
        beforeScript = '''
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "$(conda shell.bash hook)"
            module load phykit
        '''
    }
    withName: 'MODELTEST_NG' {
        beforeScript = 'module load modeltest-ng'
    }
    withName: 'IQTREE_MF|IQTREE_BOOTSTRAP' {
        beforeScript = 'module load iqtree'
    }
    withName: 'RAXMLNG_PARSE|RAXMLNG_ALL' {
        beforeScript = 'module load raxml-ng'
    }
}
